# ─── Database (Docker Compose defaults work out of the box) ───
DB_URL=jdbc:postgresql://localhost:5432/skywings
DB_USERNAME=skywings
DB_PASSWORD=skywings_dev

# ─── JWT ───
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters

# ─── SendGrid (Email OTP + booking confirmations) ───
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your-verified-email@gmail.com
SENDGRID_FROM_NAME=SkyWings Airways

# ─── Twilio (SMS OTP) ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── SerpAPI (Google Flights real-time data) ───
SERPAPI_API_KEY=your_serpapi_api_key

# ─── Frontend ───
VITE_API_URL=http://localhost:8080/api
